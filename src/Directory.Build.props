<Project>
  <Import Project="$([MSBuild]::GetPathOfFileAbove('Directory.Build.props', '$(MSBuildThisFileDirectory)../'))" />

  <PropertyGroup>
    <IsPackable>True</IsPackable>
    <SkipLocalsInit>true</SkipLocalsInit>
    <EnablePackageValidation Condition="'$(EnablePackageValidation)' == ''">true</EnablePackageValidation>
    <PublicApiGeneratorGenerateOnBuild Condition="'$(ContinuousIntegrationBuild)' == 'true' and '$(PublicApiGeneratorGenerateOnBuild)' == ''">false</PublicApiGeneratorGenerateOnBuild>
    <PublicApiGeneratorVerifyNoChangeOnBuild Condition="'$(ContinuousIntegrationBuild)' == 'true' and '$(PublicApiGeneratorVerifyNoChangeOnBuild)' == ''">true</PublicApiGeneratorVerifyNoChangeOnBuild>
    <PublicApiGeneratorGenerateOnBuild Condition="'$(PublicApiGeneratorGenerateOnBuild)' == ''">true</PublicApiGeneratorGenerateOnBuild>
    <PublicApiGeneratorVerifyNoChangeOnBuild Condition="'$(PublicApiGeneratorVerifyNoChangeOnBuild)' == ''">false</PublicApiGeneratorVerifyNoChangeOnBuild>
    <PublicApiGeneratorFileLayout Condition="'$(PublicApiGeneratorFileLayout)' == ''">SingleFile</PublicApiGeneratorFileLayout>
    <PublicApiGeneratorIncludeAutoGeneratedComment Condition="'$(PublicApiGeneratorIncludeAutoGeneratedComment)' == ''">true</PublicApiGeneratorIncludeAutoGeneratedComment>
  </PropertyGroup>

</Project>
