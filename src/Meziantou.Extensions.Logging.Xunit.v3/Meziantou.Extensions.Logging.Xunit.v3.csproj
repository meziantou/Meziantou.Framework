<Project Sdk="Meziantou.NET.Sdk">

  <PropertyGroup>
    <TargetFrameworks>$(LatestTargetFrameworks)</TargetFrameworks>
    <IsTrimmable>false</IsTrimmable>

    <Description>Microsoft.Extension.Logging.ILogger implementation for xunit.v3</Description>
    <PackageTags>xunit, xunit.v3, logger</PackageTags>
    <Version>2.0.1</Version>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="../../common/TypeNameHelper.cs" Link="TypeNameHelper.cs" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" Version="10.0.8" />
    <PackageReference Include="xunit.v3.extensibility.core" Version="3.2.2" />
  </ItemGroup>

</Project>
