<Project Sdk="Meziantou.NET.Sdk">

  <PropertyGroup>
    <TargetFrameworks>$(LatestTargetFrameworks)</TargetFrameworks>
    <RootNamespace>Meziantou.Framework.Assertions</RootNamespace>
    <Version>1.0.1</Version>
    <Description>Assertion helpers for .NET tests</Description>
  </PropertyGroup>

  <ItemGroup>
    <None Include="$(OutputPath)/../../Meziantou.Framework.Assertions.Analyzer/$(Configuration.ToLowerInvariant())_netstandard2.0/Meziantou.Framework.Assertions.Analyzer.dll" Pack="true" PackagePath="analyzers/dotnet/cs" Visible="false" />
    <None Include="$(OutputPath)/../../Meziantou.Framework.Assertions.CodeFix/$(Configuration.ToLowerInvariant())_netstandard2.0/Meziantou.Framework.Assertions.CodeFix.dll" Pack="true" PackagePath="analyzers/dotnet/cs" Visible="false" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="../Meziantou.Framework.Assertions.Analyzer/Meziantou.Framework.Assertions.Analyzer.csproj" ReferenceOutputAssembly="false" PrivateAssets="all" />
    <ProjectReference Include="../Meziantou.Framework.Assertions.CodeFix/Meziantou.Framework.Assertions.CodeFix.csproj" ReferenceOutputAssembly="false" PrivateAssets="all" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="Meziantou.Framework.Assertions.Tests" />
  </ItemGroup>

</Project>
