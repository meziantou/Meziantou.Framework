<Project Sdk="Meziantou.NET.Sdk">

  <PropertyGroup>
    <TargetFrameworks>$(LatestTargetFrameworks)</TargetFrameworks>
    <RootNamespace>Meziantou.Framework.Sanitizers</RootNamespace>
    <Version>2.0.14</Version>
    <IsTrimmable>false</IsTrimmable>
    <Description>Provide helpers to sanitize HTML fragment</Description>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="../Meziantou.Framework.Html/*.cs" LinkBase="Html" Exclude="../Meziantou.Framework.Html/HtmlXmlWriter.cs;../Meziantou.Framework.Html/HtmlNodeExtensions.cs;../Meziantou.Framework.Html/HtmlMicroDataExtensions.cs" />
  </ItemGroup>

</Project>
