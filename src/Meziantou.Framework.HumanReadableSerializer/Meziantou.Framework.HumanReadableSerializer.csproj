<Project Sdk="Meziantou.NET.Sdk">

  <PropertyGroup>
    <TargetFrameworks>$(LatestTargetFrameworks)</TargetFrameworks>
    <RootNamespace>Meziantou.Framework.HumanReadable</RootNamespace>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <Description>One-way serializer to a human readable format</Description>
    <Version>3.0.0</Version>
  </PropertyGroup>

  <ItemGroup>
    <Using Include="System.Net.Http" />
  </ItemGroup>

  <ItemGroup>
    <Compile Include="../Meziantou.Framework.Html/*.cs" LinkBase="Html" Exclude="../Meziantou.Framework.Html/HtmlXmlWriter.cs;../Meziantou.Framework.Html/HtmlNodeExtensions.cs;../Meziantou.Framework.Html/HtmlMicroDataExtensions.cs" />
  </ItemGroup>

</Project>
