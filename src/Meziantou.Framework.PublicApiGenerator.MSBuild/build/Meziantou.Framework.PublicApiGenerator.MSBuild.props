<Project>
  <PropertyGroup>
    <PublicApiGeneratorGenerateOnBuild Condition="'$(PublicApiGeneratorGenerateOnBuild)' == ''">true</PublicApiGeneratorGenerateOnBuild>
    <PublicApiGeneratorFileLayout Condition="'$(PublicApiGeneratorFileLayout)' == ''">SingleFile</PublicApiGeneratorFileLayout>
    <PublicApiGeneratorIncludeAutoGeneratedComment Condition="'$(PublicApiGeneratorIncludeAutoGeneratedComment)' == ''">true</PublicApiGeneratorIncludeAutoGeneratedComment>
  </PropertyGroup>
</Project>
