<Project>
  <PropertyGroup>
    <_PublicApiGeneratorTaskAssemblyPath>$([MSBuild]::NormalizePath('$(MSBuildThisFileDirectory)', '..', 'tasks', 'net8.0', 'Meziantou.Framework.PublicApiGenerator.MSBuild.dll'))</_PublicApiGeneratorTaskAssemblyPath>
    <_PublicApiGeneratorResolvedOutputPath Condition="'$(PublicApiGeneratorOutputPath)' != ''">$([MSBuild]::NormalizePath('$(MSBuildProjectDirectory)', '$(PublicApiGeneratorOutputPath)'))</_PublicApiGeneratorResolvedOutputPath>
  </PropertyGroup>

  <UsingTask TaskName="Meziantou.Framework.PublicApiGenerator.MSBuild.GeneratePublicApiTask"
             AssemblyFile="$(_PublicApiGeneratorTaskAssemblyPath)"
             Condition="Exists('$(_PublicApiGeneratorTaskAssemblyPath)')" />

  <Target Name="_PublicApiGeneratorValidateConfiguration"
          Condition="'$(PublicApiGeneratorGenerateOnBuild)' == 'true' and '$(DesignTimeBuild)' != 'true'">
    <Error Condition="'$(PublicApiGeneratorOutputPath)' == ''"
           Text="The 'PublicApiGeneratorOutputPath' property must be set when 'PublicApiGeneratorGenerateOnBuild' is true." />
  </Target>

  <Target Name="GeneratePublicApiOnBuild"
          AfterTargets="Build"
          DependsOnTargets="_PublicApiGeneratorValidateConfiguration"
          Condition="'$(PublicApiGeneratorGenerateOnBuild)' == 'true' and '$(DesignTimeBuild)' != 'true' and '$(IsCrossTargetingBuild)' == 'true' and '$(TargetFrameworks)' != ''">
    <ItemGroup>
      <_PublicApiGeneratorTargetFramework Include="$(TargetFrameworks)" />
    </ItemGroup>

    <MSBuild Projects="$(MSBuildProjectFullPath)"
             Targets="_PublicApiGeneratorGetBuildOutput"
             BuildInParallel="true"
             RemoveProperties="TargetFrameworks"
             Properties="TargetFramework=%(_PublicApiGeneratorTargetFramework.Identity)">
      <Output TaskParameter="TargetOutputs" ItemName="_PublicApiGeneratorAssembly" />
    </MSBuild>

    <Error Condition="'@(_PublicApiGeneratorAssembly)' == ''"
           Text="No build output assembly was found to generate the public API for project '$(MSBuildProjectName)'." />

    <GeneratePublicApiTask Assemblies="@(_PublicApiGeneratorAssembly)"
                           OutputPath="$(_PublicApiGeneratorResolvedOutputPath)"
                           FileLayout="$(PublicApiGeneratorFileLayout)"
                           IncludeAutoGeneratedComment="$(PublicApiGeneratorIncludeAutoGeneratedComment)" />
  </Target>
</Project>
