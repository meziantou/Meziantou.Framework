<Project Sdk="Meziantou.NET.Sdk">

  <PropertyGroup>
    <TargetFrameworks>$(LatestTargetFrameworks)</TargetFrameworks>
    <RootNamespace>Meziantou.Framework</RootNamespace>
    <Version>1.0.4</Version>
    <IsTrimmable>true</IsTrimmable>
    <Description>QR Code generation with SVG and console renderers</Description>
    <NoWarn>$(NoWarn);CA1814</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="System.Text.Encoding.CodePages" Version="10.0.5" />
  </ItemGroup>

</Project>
