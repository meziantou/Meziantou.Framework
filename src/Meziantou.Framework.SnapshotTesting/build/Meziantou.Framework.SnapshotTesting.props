<Project>
  <Target Name="GenerateSnapshotTestingSourceRoots"
          DependsOnTargets="InitializeSourceRootMappedPaths"
          BeforeTargets="CoreCompile"
          Condition="'$(SnapshotTestingGenerateSourceRoot)' != 'false' and '$(DeterministicSourcePaths)' == 'true'">

    <PropertyGroup>
      <_SnapshotTestingSourceRootFile>$(IntermediateOutputPath)SnapshotTestingSourceRoot.g.cs</_SnapshotTestingSourceRootFile>
      <_SnapshotTestingSourceRootNamespace Condition="'$(RootNamespace)' != ''">$(RootNamespace)</_SnapshotTestingSourceRootNamespace>
      <_SnapshotTestingSourceRootNamespace Condition="'$(_SnapshotTestingSourceRootNamespace)' == ''">$(MSBuildProjectName)</_SnapshotTestingSourceRootNamespace>
    </PropertyGroup>

    <ItemGroup>
      <_SnapshotTestingSourceRoot Include="@(SourceRoot)"
          Condition="'%(SourceRoot.NestedRoot)' == '' and '%(SourceRoot.MappedPath)' != ''">
        <NormalizedIdentity>$([System.String]::Copy('%(Identity)').Replace('\', '/'))</NormalizedIdentity>
      </_SnapshotTestingSourceRoot>
    </ItemGroup>

    <ItemGroup>
      <_SnapshotTestingSourceRootRegistrationLines
          Include="@(_SnapshotTestingSourceRoot->'        global::Meziantou.Framework.SnapshotTesting.Snapshot.RegisterSourceRootMapping(%22%(MappedPath)%22, %22%(NormalizedIdentity)%22)%3B')" />
    </ItemGroup>

    <ItemGroup Condition="'@(_SnapshotTestingSourceRootRegistrationLines)' != ''">
      <_SnapshotTestingSourceRootFileLines Include="// &lt;auto-generated/&gt;" />
      <_SnapshotTestingSourceRootFileLines Include="using System.Runtime.CompilerServices%3B" />
      <_SnapshotTestingSourceRootFileLines Include=" " />
      <_SnapshotTestingSourceRootFileLines Include="[assembly: System.Reflection.AssemblyMetadata(%22SnapshotTestingSourceRootMappings%22, %22generated%22)]" />
      <_SnapshotTestingSourceRootFileLines Include=" " />
      <_SnapshotTestingSourceRootFileLines Include="namespace $(_SnapshotTestingSourceRootNamespace)%3B" />
      <_SnapshotTestingSourceRootFileLines Include=" " />
      <_SnapshotTestingSourceRootFileLines Include="[System.CodeDom.Compiler.GeneratedCode(%22Meziantou.Framework.SourceRootRegistration%22, %22%22)]" />
      <_SnapshotTestingSourceRootFileLines Include="internal static class SnapshotTestingSourceRootInitializer" />
      <_SnapshotTestingSourceRootFileLines Include="{" />
      <_SnapshotTestingSourceRootFileLines Include="    [ModuleInitializer]" />
      <_SnapshotTestingSourceRootFileLines Include="    internal static void Initialize()" />
      <_SnapshotTestingSourceRootFileLines Include="    {" />
      <_SnapshotTestingSourceRootFileLines Include="@(_SnapshotTestingSourceRootRegistrationLines)" />
      <_SnapshotTestingSourceRootFileLines Include="    }" />
      <_SnapshotTestingSourceRootFileLines Include="}" />
    </ItemGroup>

    <WriteLinesToFile
        File="$(_SnapshotTestingSourceRootFile)"
        Lines="@(_SnapshotTestingSourceRootFileLines)"
        Overwrite="true"
        WriteOnlyWhenDifferent="true"
        Condition="'@(_SnapshotTestingSourceRootFileLines)' != ''" />

    <ItemGroup Condition="'@(_SnapshotTestingSourceRootFileLines)' != ''">
      <Compile Include="$(_SnapshotTestingSourceRootFile)" />
      <EmbedInBinlog Include="$(_SnapshotTestingSourceRootFile)" />
    </ItemGroup>

    <ItemGroup>
      <_SnapshotTestingSourceRoot Remove="@(_SnapshotTestingSourceRoot)" />
      <_SnapshotTestingSourceRootRegistrationLines Remove="@(_SnapshotTestingSourceRootRegistrationLines)" />
      <_SnapshotTestingSourceRootFileLines Remove="@(_SnapshotTestingSourceRootFileLines)" />
    </ItemGroup>
  </Target>
</Project>
