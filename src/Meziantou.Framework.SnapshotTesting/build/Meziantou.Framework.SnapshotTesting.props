<Project>
  <!--
    Generates a C# file in the intermediate output folder that registers the MSBuild PathMap
    mappings (the deterministic path prefixes such as /_/ or /_1/ used during deterministic builds)
    with SnapshotConfiguration via a [ModuleInitializer] so that file-based snapshot tests can
    resolve CallerFilePath values back to real paths on disk in CI environments.

    The $(PathMap) property is set by the _SetPathMapFromSourceRoots target in the .NET SDK when
    deterministic builds are active. Its format is: realPath1=/_/,realPath2=/_1/,...

    Set $(SnapshotTestingGenerateSourceRoot) to 'false' to opt out of this code generation.
  -->
  <Target Name="GenerateSnapshotTestingSourceRoots"
          AfterTargets="_SetPathMapFromSourceRoots"
          BeforeTargets="CoreCompile"
          Condition="'$(SnapshotTestingGenerateSourceRoot)' != 'false'">

    <PropertyGroup>
      <_SnapshotTestingSourceRootFile>$(IntermediateOutputPath)SnapshotTestingSourceRoot.g.cs</_SnapshotTestingSourceRootFile>
      <!-- Normalize backslashes so the embedded string literal is always valid -->
      <_SnapshotTestingNormalizedPathMap>$(PathMap.Replace('\', '/'))</_SnapshotTestingNormalizedPathMap>
    </PropertyGroup>

    <!-- Only generate the file when PathMap is non-empty (i.e. deterministic builds are active) -->
    <ItemGroup Condition="'$(_SnapshotTestingNormalizedPathMap)' != ''">
      <_SnapshotTestingSourceRootFileLines
          Include="// &lt;auto-generated/&gt;
using System.Runtime.CompilerServices%3B

namespace Meziantou.Framework.SnapshotTesting%3B

[assembly: System.Reflection.AssemblyMetadata(%22SnapshotTestingSourceRootMappings%22, %22generated%22)]

internal static class SnapshotTestingSourceRootInitializer
{
    [ModuleInitializer]
    internal static void Initialize()
    {
        global::Meziantou.Framework.SnapshotTesting.SnapshotConfiguration.RegisterPathMap(%22$(_SnapshotTestingNormalizedPathMap)%22)%3B
    }
}" />
    </ItemGroup>

    <WriteLinesToFile
        File="$(_SnapshotTestingSourceRootFile)"
        Lines="@(_SnapshotTestingSourceRootFileLines)"
        Overwrite="true"
        WriteOnlyWhenDifferent="true"
        Condition="'@(_SnapshotTestingSourceRootFileLines)' != ''" />

    <ItemGroup Condition="'@(_SnapshotTestingSourceRootFileLines)' != ''">
      <Compile Include="$(_SnapshotTestingSourceRootFile)" />
      <EmbedInBinlog Include="$(_SnapshotTestingSourceRootFile)" />
    </ItemGroup>

    <!-- Clean up temporary items -->
    <ItemGroup>
      <_SnapshotTestingNormalizedPathMap Remove="@(_SnapshotTestingNormalizedPathMap)" />
      <_SnapshotTestingSourceRootFileLines Remove="@(_SnapshotTestingSourceRootFileLines)" />
    </ItemGroup>
  </Target>
</Project>
