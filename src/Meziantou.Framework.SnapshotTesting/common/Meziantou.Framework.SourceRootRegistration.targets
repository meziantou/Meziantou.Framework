<Project>
  <Target Name="_MeziantouGenerateSourceRootsCore">

    <PropertyGroup>
      <_MeziantouSourceRootFile>$([MSBuild]::NormalizePath('$(MSBuildProjectDirectory)', '$(IntermediateOutputPath)', '$(_MeziantouSourceRootGeneratedFileName)'))</_MeziantouSourceRootFile>
      <_MeziantouSourceRootNamespaceHash>$([MSBuild]::StableStringHash('$(MSBuildProjectFullPath)|$(_MeziantouSourceRootGeneratedFileName)|$(_MeziantouSourceRootAssemblyMetadataName)|$(_MeziantouSourceRootInitializerClassName)', 'SHA256'))</_MeziantouSourceRootNamespaceHash>
      <_MeziantouSourceRootNamespace>Meziantou.Framework.SourceRootRegistration.N$(_MeziantouSourceRootNamespaceHash)</_MeziantouSourceRootNamespace>
      <_MeziantouSourceRootInitializerMethodName>Initialize$(_MeziantouSourceRootNamespaceHash)</_MeziantouSourceRootInitializerMethodName>
    </PropertyGroup>

    <ItemGroup>
      <_MeziantouSourceRoot Include="@(SourceRoot)"
          Condition="'%(SourceRoot.NestedRoot)' == '' and '%(SourceRoot.MappedPath)' != ''">
        <NormalizedIdentity>$([System.String]::Copy('%(Identity)').Replace('\', '/'))</NormalizedIdentity>
      </_MeziantouSourceRoot>
    </ItemGroup>

    <ItemGroup>
      <_MeziantouSourceRootRegistrationLines
          Include="@(_MeziantouSourceRoot->'        $(_MeziantouSourceRootRegistrationMethod)(%22%(MappedPath)%22, %22%(NormalizedIdentity)%22)%3B')" />
    </ItemGroup>

    <ItemGroup Condition="'@(_MeziantouSourceRootRegistrationLines)' != ''">
      <_MeziantouSourceRootFileLines Include="// &lt;auto-generated/&gt;" />
      <_MeziantouSourceRootFileLines Include="#pragma warning disable" />
      <_MeziantouSourceRootFileLines Include="using System.Runtime.CompilerServices%3B" />
      <_MeziantouSourceRootFileLines Include=" " />
      <_MeziantouSourceRootFileLines Include="[assembly: System.Reflection.AssemblyMetadata(%22$(_MeziantouSourceRootAssemblyMetadataName)%22, %22generated%22)]" />
      <_MeziantouSourceRootFileLines Include=" " />
      <_MeziantouSourceRootFileLines Include="namespace $(_MeziantouSourceRootNamespace)%3B" />
      <_MeziantouSourceRootFileLines Include=" " />
      <_MeziantouSourceRootFileLines Include="[System.CodeDom.Compiler.GeneratedCode(%22Meziantou.Framework.SourceRootRegistration%22, %22%22)]" />
      <_MeziantouSourceRootFileLines Include="internal static partial class $(_MeziantouSourceRootInitializerClassName)" />
      <_MeziantouSourceRootFileLines Include="{" />
      <_MeziantouSourceRootFileLines Include="    [ModuleInitializer]" />
      <_MeziantouSourceRootFileLines Include="    internal static void $(_MeziantouSourceRootInitializerMethodName)()" />
      <_MeziantouSourceRootFileLines Include="    {" />
      <_MeziantouSourceRootFileLines Include="@(_MeziantouSourceRootRegistrationLines)" />
      <_MeziantouSourceRootFileLines Include="    }" />
      <_MeziantouSourceRootFileLines Include="}" />
    </ItemGroup>

    <WriteLinesToFile
        File="$(_MeziantouSourceRootFile)"
        Lines="@(_MeziantouSourceRootFileLines)"
        Overwrite="true"
        WriteOnlyWhenDifferent="true"
        Condition="'@(_MeziantouSourceRootFileLines)' != ''" />

    <ItemGroup Condition="'@(_MeziantouSourceRootFileLines)' != ''">
      <Compile Include="$(_MeziantouSourceRootFile)" />
      <EmbedInBinlog Include="$(_MeziantouSourceRootFile)" />
    </ItemGroup>

    <ItemGroup>
      <_MeziantouSourceRoot Remove="@(_MeziantouSourceRoot)" />
      <_MeziantouSourceRootRegistrationLines Remove="@(_MeziantouSourceRootRegistrationLines)" />
      <_MeziantouSourceRootFileLines Remove="@(_MeziantouSourceRootFileLines)" />
    </ItemGroup>
  </Target>
</Project>
